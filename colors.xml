<theme>
	<colorScheme name="dracula">
        <variables>
			<background>282A36</background>		<!-- Main background -->
			<currentLine>6272A4</currentLine>	<!-- Line highlight -->
			<selection>44475A</selection>		<!-- Text selection -->
			<foreground>F8F8F2</foreground>		<!-- Default text -->
			<comment>6272A4</comment>			<!-- Comments, disabled code -->
			<red>FF5555</red>					<!-- Errors, warnings, deletion -->
			<orange>FFB86C</orange>				<!-- Numbers, constants, booleans -->
			<yellow>F1FA8C</yellow>				<!-- Functions, methods -->
			<green>50FA7B</green>				<!-- Strings, inherited classes -->
			<cyan>8BE9FD</cyan>					<!-- Support functions, regex -->
			<purple>BD93F9</purple>				<!-- Classes, types, variables -->
			<pink>FF79C6</pink>					<!-- Keywords, storage types -->
			<floatingInteractiveElements>343746</floatingInteractiveElements>		
			<backgroundLighter>424450</backgroundLighter>	
			<backgroundLight>343746</backgroundLight>		
			<backgroundDark>21222C</backgroundDark>			
			<backgroundDarker>191A21</backgroundDarker>		
			<functionalRed>DE5735</functionalRed>				<!-- Critical actions, alerts -->
			<functionalOrange>A39514</functionalOrange>			<!-- Warnings, notifications -->
			<functionalGreen>089108</functionalGreen>			<!-- Success states -->
			<functionalCyan>0081D6</functionalCyan>				<!-- Information, links -->
			<functionalPurple>815CD6</functionalPurple>			<!-- Focus indicators -->
			<palette>dracula</palette>
		</variables>
    </colorScheme>
	<colorScheme name="alucard">
        <variables>
			<background>FFFBEB</background>		<!-- Main background -->
			<currentLine>6C664B</currentLine>	<!-- Line highlight -->
			<selection>CFCFDE</selection>		<!-- Text selection -->
			<foreground>1F1F1F</foreground>		<!-- Default text -->
			<comment>6C664B</comment>			<!-- Comments, disabled code -->
			<red>CB3A2A</red>					<!-- Errors, warnings, deletion -->
			<orange>A34D14</orange>				<!-- Numbers, constants, booleans -->
			<yellow>846E15</yellow>				<!-- Functions, methods -->
			<green>14710A</green>				<!-- Strings, inherited classes -->
			<cyan>036A96</cyan>					<!-- Support functions, regex -->
			<purple>644AC9</purple>				<!-- Classes, types, variables -->
			<pink>A3144D</pink>					<!-- Keywords, storage types -->
			<floatingInteractiveElements>EFEDDC</floatingInteractiveElements>		
			<backgroundLighter>ECE9DF</backgroundLighter>	
			<backgroundLight>DEDCCF</backgroundLight>		
			<backgroundDark>CECCC0</backgroundDark>			
			<backgroundDarker>BCBAB3</backgroundDarker>		
			<functionalRed>DE5735</functionalRed>				<!-- Critical actions, alerts -->
			<functionalOrange>A39514</functionalOrange>			<!-- Warnings, notifications -->
			<functionalGreen>089108</functionalGreen>			<!-- Success states -->
			<functionalCyan>0081D6</functionalCyan>				<!-- Information, links -->
			<functionalPurple>815CD6</functionalPurple>			<!-- Focus indicators -->
			<palette>alucard</palette>
		</variables>
    </colorScheme>
</theme>